{
  "name": "meowseo",
  "version": "1.0.0",
  "description": "MeowSEO WordPress Plugin - Gutenberg Integration",
  "main": "build/index.js",
  "scripts": {
    "build": "npm run build:gutenberg && npm run build:admin && npm run build:dashboard",
    "build:gutenberg": "wp-scripts build src/gutenberg/index.tsx --output-path=build --output-filename=gutenberg.js",
    "build:admin": "wp-scripts build src/admin-settings.js --output-path=build --output-filename=admin-settings.js",
    "build:dashboard": "wp-scripts build src/admin-dashboard.js --output-path=build --output-filename=admin-dashboard.js",
    "start": "wp-scripts start src/gutenberg/index.tsx --output-path=build",
    "start:admin": "wp-scripts start src/admin-settings.js --output-path=build --output-filename=admin-settings.js",
    "start:dashboard": "wp-scripts start src/admin-dashboard.js --output-path=build --output-filename=admin-dashboard.js",
    "lint:js": "wp-scripts lint-js src",
    "format:js": "wp-scripts format src",
    "type-check": "tsc --noEmit",
    "test": "wp-scripts test-unit-js --passWithNoTests",
    "test:watch": "wp-scripts test-unit-js --watch"
  },
  "keywords": [
    "wordpress",
    "seo",
    "gutenberg"
  ],
  "author": "MeowSEO",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@wordpress/scripts": "^27.9.0",
    "typescript": "^5.3.0",
    "ts-loader": "^9.5.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@types/jest": "^29.5.0",
    "fast-check": "^3.15.0"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^6.0.0",
    "@wordpress/block-editor": "^12.0.0",
    "@wordpress/components": "^25.0.0",
    "@wordpress/core-data": "^6.0.0",
    "@wordpress/data": "^9.0.0",
    "@wordpress/edit-post": "^7.0.0",
    "@wordpress/editor": "^13.0.0",
    "@wordpress/element": "^5.0.0",
    "@wordpress/i18n": "^4.0.0",
    "@wordpress/plugins": "^6.0.0"
  }
}
