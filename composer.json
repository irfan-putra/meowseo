{
    "name": "meowseo/meowseo",
    "description": "MeowSEO WordPress Plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "yoast/phpunit-polyfills": "^1.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.5",
        "giorgiosironi/eris": "^0.14"
    },
    "autoload": {
        "psr-4": {
            "MeowSEO\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MeowSEO\\Tests\\": "tests/"
        }
    }
}
